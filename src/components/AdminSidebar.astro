---
// src/components/AdminSidebar.astro
const pathname = Astro.url.pathname;
---

<aside class="admin-sidebar">
  <div class="sidebar-header">
    <div class="logo-icon">✦</div>
    <h2>Peniel Admin</h2>
  </div>

  <nav class="sidebar-nav">
    <a href="/admin" class={`nav-item ${pathname === '/admin' || pathname === '/admin/' ? 'active' : ''}`}>
      <span class="icon">📊</span>
      Dashboard
    </a>
    <a href="/admin/products" class={`nav-item ${pathname.includes('/admin/products') ? 'active' : ''}`}>
      <span class="icon">📦</span>
      All Products
    </a>
    <a href="/admin/add-product" class={`nav-item ${pathname.includes('/admin/add-product') ? 'active' : ''}`}>
      <span class="icon">➕</span>
      Add Product
    </a>
  </nav>

  <div class="sidebar-footer">
    <a href="/" class="nav-item back-link">
      <span class="icon">←</span>
      Back to Store
    </a>
  </div>
</aside>

<style>
  .admin-sidebar {
    width: 280px;
    height: 100vh;
    position: sticky;
    top: 0;
    background: rgba(13, 15, 20, 0.95);
    backdrop-filter: blur(20px);
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    padding: 2rem 1.5rem;
    z-index: 50;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .logo-icon {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, #c5a028, #eab308);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000;
    font-size: 1.2rem;
    font-weight: bold;
    box-shadow: 0 0 15px rgba(197, 160, 40, 0.3);
  }

  .sidebar-header h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0;
    background: linear-gradient(to right, #fff, #cbd5e1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.8rem 1rem;
    border-radius: 12px;
    color: #9ca3af;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .nav-item:hover {
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
  }

  .nav-item.active {
    background: rgba(197, 160, 40, 0.1);
    color: #c5a028;
    border: 1px solid rgba(197, 160, 40, 0.2);
  }

  .icon {
    font-size: 1.2rem;
  }

  .sidebar-footer {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .back-link {
    color: #6b7280;
  }

  .back-link:hover {
    color: #f3f4f6;
  }
</style>
