---
// BrandsScroller.astro
// Multi‑row infinite scrolling brand logos with 3D tilt – seamless loop

import { brandRows } from '../lib/brands';
---

<div class="brands-scroller-component">
  <!-- Top subtle separator -->
  <div class="separator-top"></div>

  <!-- Restored heading -->
  <div class="brands-scroller-header">
   
  </div>

  <!-- Slider container -->
  <div class="slider-container">
    <div class="wrapper-images">
      {brandRows.map((row, rowIndex) => (
        <div class="images-line" style={`--duration: ${rowIndex % 2 === 0 ? 20 : 30}s`}>
          {/* Double duplication for seamless loop: original + clone */}
          {[...row, ...row].map((brand, idx) => (
            <div
              class="line"
              style={`background-image: url(${brand.url})`}
              title={brand.name}
            >
              <span
                class="img"
                style={`background-image: url(${brand.url})`}
                aria-label={brand.name}
              />
              <span class="brand-name">{brand.name}</span>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom subtle separator -->
  <div class="separator-bottom"></div>
</div>

<style is:global>
  .brands-scroller-component * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .brands-scroller-component {
    display: block;
    width: 100%;
    overflow-x: clip;
    background: linear-gradient(180deg, var(--bg-primary) 0%, #050505 100%);
    position: relative;
    z-index: 1;
  }

  /* Subtle separators */
  .separator-top,
  .separator-bottom {
    width: 100%;
    height: 4rem;
    background: linear-gradient(180deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0) 100%);
    pointer-events: none;
  }
  .separator-bottom {
    background: linear-gradient(0deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0) 100%);
  }

  /* Heading - fully visible, not overlapped */
  .brands-scroller-header {
    text-align: center;
    margin: 2rem 1rem 3rem;  /* increased bottom margin to avoid overlap */
    position: relative;
    z-index: 2;
    background: transparent;
  }
  .brands-scroller-header h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent-gold);
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
  }
  .brands-scroller-header p {
    color: var(--text-secondary);
    font-size: 1rem;
  }

  /* Slider container - gives room */
  .slider-container {
    margin: 0 auto;
    padding: 1rem 0 2rem;
    overflow: visible;
    position: relative;
    z-index: 1;
  }

  /* 3D wrapper */
  .wrapper-images {
    display: flex;
    flex-direction: column;
    height: 100vh;
    min-height: 380px;
    max-height: 70vh;
    justify-content: center;
    left: 50%;
    position: relative;
    top: 0;
    opacity: 0.85;
    transform: translate3d(-50%, 0, 0) perspective(800px) rotateY(10deg) rotateX(-10deg);
    width: 100vw;
    margin: 0 auto;
    pointer-events: none;
  }

  /* Each row – now animates from 0 to -50% for seamless loop */
  .images-line {
    animation: runner var(--duration, 20s) linear infinite;
    display: flex;
    transform: translateX(0);
    pointer-events: auto;
    width: fit-content;
  }

  /* Brand card */
  .line {
    background-position: 50% 50%;
    background-size: cover;
    flex: none;
    height: 22vh;
    aspect-ratio: 1 / 1.1;
    min-width: 120px;
    max-width: 180px;
    margin: clamp(6px, 2vw, 16px);
    position: relative;
    transition: box-shadow 0.3s, filter 0.3s;
    border-radius: 1rem;
    overflow: visible;
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.5);
    cursor: pointer;
  }

  .img {
    position: absolute;
    z-index: 2;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    background-position: 50% 50%;
    background-size: cover;
    transition: transform 0.3s, filter 0.3s;
    border-radius: 1rem;
  }

  .line:hover .img {
    cursor: pointer;
    transform: scale(1.12) translateZ(0px);
    box-shadow: 0 18px 32px rgba(0, 0, 0, 0.6);
    filter: blur(0px) brightness(1.08);
  }

  .line:after {
    content: "";
    background: inherit;
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    top: 3vh;
    position: absolute;
    background-size: cover;
    z-index: -1;
    transition: filter 0.3s;
    filter: blur(20px) opacity(0.6);
  }

  .line:hover:after {
    filter: blur(35px) opacity(0.85);
  }

  .brand-name {
    position: absolute;
    bottom: -1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--accent-gold);
    white-space: nowrap;
    background: rgba(15, 15, 15, 0.9);
    padding: 0.2rem 0.5rem;
    border-radius: 1rem;
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
    border: 1px solid var(--border);
  }

  .line:hover .brand-name {
    opacity: 1;
  }

  /* Seamless infinite scroll: move left by exactly half the total width (since we duplicated the row) */
  @keyframes runner {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Responsive */
  @media (max-width: 1000px) {
    .wrapper-images {
      height: 66vh;
      min-height: 200px;
      max-height: 300px;
      padding-top: 2vh;
    }
    .line {
      min-width: 85px;
      max-width: 120px;
      margin: 4px;
      height: 13vh;
    }
    .brands-scroller-header h2 {
      font-size: 1.5rem;
    }
    .brands-scroller-header {
      margin-bottom: 2rem;
    }
    .separator-top,
    .separator-bottom {
      height: 2rem;
    }
  }

  @media (max-width: 600px) {
    .wrapper-images {
      height: 50vw;
      min-height: 120px;
      max-height: 180px;
      padding-top: 2vw;
    }
    .line {
      min-width: 66px;
      max-width: 85px;
      margin: 3px;
      height: 7.4vh;
    }
    .brand-name {
      font-size: 0.5rem;
      bottom: -1.2rem;
    }
    .brands-scroller-header h2 {
      font-size: 1.2rem;
    }
    .brands-scroller-header p {
      font-size: 0.8rem;
    }
    .brands-scroller-header {
      margin-bottom: 1.5rem;
    }
    .separator-top,
    .separator-bottom {
      height: 1.5rem;
    }
  }
</style>
