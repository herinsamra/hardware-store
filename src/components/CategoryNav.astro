---
import { categories } from '../lib/categories';
---

<nav class="category-nav">
  <div class="category-nav-container">
    {Object.entries(categories).map(([catName, subcats]) => (
      <div class="category-dropdown">
        <button class="category-btn">{catName}</button>
        <div class="dropdown-content">
          {Object.entries(subcats).map(([subcatName, subsubcats]) => (
            <div class="subcategory-group">
              <strong>{subcatName}</strong>
              {Object.keys(subsubcats).map(subsub => (
                <a href={`/products?category=${encodeURIComponent(catName)}&subcategory=${encodeURIComponent(subcatName)}&subsub=${encodeURIComponent(subsub)}`}>
                  {subsub}
                </a>
              ))}
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</nav>

<style>
  /* (keep your existing styles) */
  .category-nav {
    background: #f8f9fa;
    border-bottom: 1px solid #dee2e6;
    position: sticky;
    top: 100px;
    z-index: 99;
  }
  .category-nav-container {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0.5rem 1rem;
  }
  .category-dropdown {
    position: relative;
    display: inline-block;
  }
  .category-btn {
    background: none;
    border: none;
    padding: 0.5rem 1rem;
    font-weight: 600;
    cursor: pointer;
    font-size: 1rem;
  }
  .dropdown-content {
    display: none;
    position: absolute;
    background: white;
    min-width: 200px;
    box-shadow: 0 8px 16px rgba(0,0,0,0.1);
    z-index: 1;
    padding: 0.5rem;
    border-radius: 8px;
  }
  .category-dropdown:hover .dropdown-content {
    display: block;
  }
  .subcategory-group {
    margin-bottom: 0.5rem;
    padding: 0.25rem 0;
  }
  .subcategory-group strong {
    display: block;
    font-size: 0.875rem;
    color: #1a472a;
    margin-bottom: 0.25rem;
  }
  .subcategory-group a {
    display: block;
    padding: 0.25rem 0.5rem;
    text-decoration: none;
    color: #333;
    font-size: 0.875rem;
  }
  .subcategory-group a:hover {
    background: #e9ecef;
  }
  @media (max-width: 768px) {
    .category-nav-container {
      overflow-x: auto;
      justify-content: flex-start;
      flex-wrap: nowrap;
      -webkit-overflow-scrolling: touch;
    }
    .category-btn {
      white-space: nowrap;
    }
  }
</style>