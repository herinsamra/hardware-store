            </svg>
            <div>
              <a href="tel:+919488614888">094886 14888</a> <span class="small"></span><br />
              <a href="tel:+919488624888">094886 24888</a> <span class="small"></span>
            </div>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
              <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
              <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
            </svg>
            <a href="mailto:penielhardwares@gmail.com">penielhardwares@gmail.com</a>
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
            </svg>
            <div>
              Mon – Sat: 9:00 AM – 8:30 PM<br />
              <span class="closed">Sunday: Closed</span>
            </div>
          </li>
        </ul>
      </div>

      <!-- WhatsApp -->
      <div class="footer-whatsapp">
        <a href="https://wa.me/919488614888" target="_blank" class="whatsapp-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12.032 2c-5.523 0-10 4.477-10 10 0 1.887.523 3.66 1.437 5.186l-1.494 4.833 4.976-1.418A9.961 9.961 0 0012.032 22c5.523 0 10-4.477 10-10s-4.477-10-10-10zm0 1.5c4.695 0 8.5 3.805 8.5 8.5s-3.805 8.5-8.5 8.5a8.46 8.46 0 01-4.554-1.307l-.288-.172-2.972.846.857-2.83-.179-.293A8.434 8.434 0 013.532 12c0-4.695 3.805-8.5 8.5-8.5zM8.752 7.388c-.138 0-.358.048-.552.24-.194.192-.735.72-.735 1.756 0 1.036.756 2.038.86 2.178.104.14 1.43 2.247 3.496 3.057.488.19.946.302 1.316.382.553.144 1.056.124 1.453.074.446-.056 1.366-.564 1.558-1.108.192-.544.192-1.01.135-1.107-.057-.097-.21-.156-.438-.273-.228-.117-1.348-.665-1.556-.74-.208-.076-.36-.117-.512.117-.152.234-.588.74-.72.892-.133.152-.266.171-.494.058-.228-.113-.962-.355-1.832-1.13-.677-.604-1.135-1.35-1.267-1.578-.132-.228-.014-.35.1-.464.102-.102.228-.267.342-.4.114-.133.152-.228.228-.38.076-.152.038-.285-.019-.399-.057-.114-.512-1.235-.702-1.69-.185-.446-.373-.386-.512-.394-.133-.008-.286-.008-.438-.008z"/>
