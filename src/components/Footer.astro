    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Peniel Hardwares. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  /* ===== FOOTER STYLES ===== */
  .main-footer {
    width: 100%;
    background: var(--glass-bg-strong);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid var(--glass-border);
    margin-top: 4rem;
    padding: 3rem 1.5rem 1.5rem;
    box-shadow: var(--glass-shadow);
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
  }

  /* Desktop grid: 4 equal columns */
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  /* Brand column */
  .footer-logo {
    display: inline-block;
    text-decoration: none;
    margin-bottom: 1rem;
  }
  .logo-text {
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: -0.5px;
    background: linear-gradient(135deg, #ffffff, var(--accent-gold));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .logo-text span {
    background: none;
    color: var(--accent-gold);
    -webkit-background-clip: unset;
    background-clip: unset;
  }
  .brand-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 1rem;
  }
  .address {
    display: flex;
    gap: 0.6rem;
    color: var(--text-secondary);
    font-size: 0.85rem;
    line-height: 1.4;
  }
  .address svg {
    flex-shrink: 0;
    color: var(--accent-gold);
    margin-top: 0.2rem;
  }

  /* Headings */
  .footer-links h3, .footer-contact h3 {
    color: var(--text-primary);
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1.2rem;
  }

  /* Lists */
  .footer-links ul, .footer-contact ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-links li, .footer-contact li {
    margin-bottom: 0.7rem;
  }
  .footer-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .footer-links a:hover {
    color: var(--accent-gold);
  }
  .footer-contact li {
    display: flex;
    gap: 0.8rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }
  .footer-contact svg {
    flex-shrink: 0;
    color: var(--accent-gold);
    margin-top: 0.2rem;
  }
  .footer-contact a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-contact a:hover {
    color: var(--accent-gold);
  }
  .small {
    font-size: 0.7rem;
    opacity: 0.7;
  }
  .closed {
    color: #ef4444;
    font-weight: 500;
  }

  /* WhatsApp button */
  .footer-whatsapp {
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
  }
  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #25D366;
    color: white;
    padding: 0.7rem 1.3rem;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.2s ease;
    box-shadow: 0 4px 12px rgba(37, 211, 102, 0.3);
  }
  .whatsapp-btn:hover {
    background: #128C7E;
    transform: scale(1.02);
    box-shadow: 0 6px 16px rgba(37, 211, 102, 0.4);
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
    text-align: center;
  }
  .footer-bottom p {
    color: var(--text-secondary);
    font-size: 0.8rem;
    margin: 0;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .main-footer {
      padding: 2rem 1rem 1rem;
    }
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.8rem;
    }
    .footer-brand {
      grid-column: span 2;
    }
    .footer-whatsapp {
      grid-column: span 2;
      justify-content: center;
      margin-top: 0.5rem;
    }
    .footer-links h3, .footer-contact h3 {
      margin-bottom: 0.8rem;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      gap: 1.2rem;
    }
    .footer-contact li {
      flex-wrap: wrap;
    }
    .logo-text {
      font-size: 1.5rem;
    }
  }
</style>