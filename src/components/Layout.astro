---
import Header from './Header.astro';
import Footer from './Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  isHomePage?: boolean;
}

const { 
  title = 'Hardware Store | Quality Tools & Materials',
  description = 'Your one-stop shop for quality hardware, tools, plumbing, electrical, and building materials.',
  isHomePage = false 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta name="theme-color" content="#1a472a">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
  <div class="particles-bg" aria-hidden="true"></div>
  <div class="site-layer">
    <Header />
    
    {isHomePage ? (
      <main>
        <slot />
      </main>
    ) : (
      <main>
        <div class="container py-8">
          <slot />
        </div>
      </main>
    )}
    
    <Footer />
  </div>
  
  <script is:inline>
    // Netlify Identity Widget
    (function() {
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', function(user) {
          if (!user) {
            window.netlifyIdentity.on('login', function() {
              document.location.href = '/admin/';
            });
          }
        });
      }
    })();
  </script>
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" is:inline></script>
</body>
</html>
