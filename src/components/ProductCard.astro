---
// src/components/ProductCard.astro
import { getProductUrl } from '../lib/products';

export interface Props {
  product: {
    id: string;
    name: string;
    price: number;
    image: string;
    category: string;
    slug?: string;
    routeParam?: string;
    url?: string;
    variant_name?: string;
  };
}

const { product } = Astro.props;
const productUrl = getProductUrl(product);
const cleanName = (value = '') => value.replace(/_/g, ' ');
---

<a href={productUrl} class="product-card group">
  <div class="product-image-wrapper">
    {product.image ? (
      <img 
        src={product.image} 
        alt={product.name} 
        class="product-image"
        loading="lazy"
      />
    ) : (
      <div class="product-image-placeholder">
        <span>No Image</span>
      </div>
    )}
  </div>
  <div class="product-info">
    <h3 class="product-name">{product.name}</h3>
    {product.variant_name && (
      <p class="product-variant">{cleanName(product.variant_name)}</p>
    )}
    <div class="product-price">MRP: ₹{product.price.toFixed(2)}</div>
    <div class="product-category">{cleanName(product.category)}</div>
  </div>
</a>

<style is:global>
  .product-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    height: 100%;
    padding: 0.95rem;
    background: linear-gradient(145deg, var(--neo-surface-base), var(--neo-surface-low));
    border-radius: 33px;
    box-shadow:
      14px 14px 28px var(--neo-shadow-dark),
      -14px -14px 28px var(--neo-shadow-light);
    border: 1px solid var(--neo-outline);
    text-decoration: none;
    overflow: hidden;
    isolation: isolate;
    transition:
      transform 0.28s ease,
      box-shadow 0.28s ease,
      border-color 0.28s ease;
  }

  .product-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.12), transparent 34%),
      radial-gradient(circle at bottom right, rgba(197, 160, 40, 0.14), transparent 28%);
    pointer-events: none;
  }

  .product-card:hover {
    transform: translateY(-8px);
    border-color: rgba(197, 160, 40, 0.24);
    box-shadow:
      18px 18px 34px rgba(5, 8, 14, 0.72),
      -16px -16px 28px rgba(103, 124, 161, 0.18),
      0 0 0 1px var(--neo-gold-glow);
  }
  .product-image-wrapper {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 24px;
    background: linear-gradient(145deg, var(--neo-surface-high), var(--neo-surface-low));
    box-shadow:
      inset 10px 10px 22px rgba(8, 11, 18, 0.42),
      inset -10px -10px 20px rgba(93, 113, 147, 0.14);
  }

  .product-image-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent 35%, rgba(9, 13, 22, 0.18));
    pointer-events: none;
  }
  .product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }
  .product-card:hover .product-image {
    transform: scale(1.07);
  }
  .product-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.05), rgba(11, 17, 28, 0.28));
    color: var(--text-secondary);
    font-size: 0.875rem;
  }
  .product-info {
    display: flex;
    flex: 1;
    flex-direction: column;
    align-items: flex-start;
    padding: 0 0.35rem 0.35rem;
  }
  .product-name {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.45rem;
    color: var(--text-primary);
    line-height: 1.4;
    min-height: 2.8em;
    text-wrap: balance;
  }
  .product-variant {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: rgba(197, 160, 40, 0.12);
    border: 1px solid rgba(197, 160, 40, 0.18);
    color: var(--accent-gold-light);
    font-size: 0.76rem;
    margin-bottom: 0.85rem;
  }
  .product-price {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent-gold);
    margin-bottom: 0.55rem;
    text-shadow: 0 0 18px rgba(197, 160, 40, 0.12);
  }
  .product-category {
    margin-top: auto;
    padding: 0.42rem 0.8rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    box-shadow:
      inset 4px 4px 8px rgba(6, 10, 17, 0.24),
      inset -3px -3px 6px rgba(96, 116, 150, 0.12);
    font-size: 0.68rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  @media (max-width: 640px) {
    .product-card {
      padding: 0.8rem;
      border-radius: 28px;
      box-shadow:
        10px 10px 20px var(--neo-shadow-dark),
        -10px -10px 20px rgba(88, 107, 140, 0.14);
    }

    .product-image-wrapper {
      border-radius: 20px;
    }
  }
</style>
