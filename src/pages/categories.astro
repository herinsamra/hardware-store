---
import Layout from '../components/Layout.astro';
import categoriesData from '../data/categories.json';

// Extract brands separately
const { Brands, ...categories } = categoriesData;
const brandList = Brands ? Object.values(Brands).flat() : [];

// Helper to create product filter URL
function getFilterUrl(category?: string, subcategory?: string, subsub?: string, brand?: string) {
  const params = new URLSearchParams();
  if (category) params.set('category', category);
  if (subcategory) params.set('subcategory', subcategory);
  if (subsub) params.set('subsub', subsub);
  if (brand) params.set('brand', brand);
  return `/products?${params.toString()}`;
}
---

<Layout title="Categories | Peniel Hardwares">
  <div class="categories-page">
    <!-- Search Bar -->
    <div class="search-section">
      <form action="/products" method="get" class="search-form">
        <input
          type="text"
          name="search"
          placeholder="Search products by name, brand, category..."
          class="search-input"
        />
        <button type="submit" class="search-btn">🔍 Search</button>
      </form>
    </div>

    <!-- Full Category Hierarchy -->
    <div class="categories-container">
      <h1 class="page-title">All Categories</h1>
      
      {Object.entries(categories).map(([catName, subcats]) => (
        <section class="category-group" key={catName}>
          <h2 class="category-heading">
            <a href={getFilterUrl(catName)} class="category-link">
              {catName}
            </a>
          </h2>
          <div class="subcategories-grid">
            {Object.entries(subcats).map(([subcatName, subsubs]) => (
              <div class="subcategory-card" key={subcatName}>
                <h3 class="subcategory-title">
                  <a href={getFilterUrl(catName, subcatName)}>
                    {subcatName}
                  </a>
                </h3>
                <ul class="subsub-list">
                  {Object.keys(subsubs).map(subsub => (
                    <li key={subsub}>
                      <a href={getFilterUrl(catName, subcatName, subsub)}>
                        {subsub}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    <!-- Brands Section -->
    {brandList.length > 0 && (
      <div class="brands-section">
        <h2 class="brands-heading">Shop by Brand</h2>
        <div class="brands-grid">
          {brandList.map(brand => (
            <a href={getFilterUrl(undefined, undefined, undefined, brand)} class="brand-chip">
              {brand}
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>

<style is:global>
  .categories-page {
    max-width: 1280px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  /* Search Bar */
  .search-section {
    margin-bottom: 3rem;
  }
  .search-form {
    display: flex;
    gap: 0.75rem;
    max-width: 600px;
    margin: 0 auto;
  }
  .search-input {
    flex: 1;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 2rem;
    padding: 0.75rem 1.25rem;
    color: var(--text-primary);
    font-size: 1rem;
    transition: 0.2s;
  }
  .search-input:focus {
    outline: none;
    border-color: var(--accent-gold);
  }
  .search-btn {
    background: var(--accent-gold);
    border: none;
    border-radius: 2rem;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    color: #0f172a;
    cursor: pointer;
    transition: 0.2s;
  }
  .search-btn:hover {
    background: var(--accent-gold-light);
    transform: scale(1.02);
  }

  /* Page Title */
  .page-title {
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--accent-gold);
    margin-bottom: 2rem;
    border-left: 5px solid var(--accent-gold);
    padding-left: 1rem;
  }

  /* Category Group */
  .category-group {
    margin-bottom: 3rem;
  }
  .category-heading {
    font-size: 1.8rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }
  .category-link {
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s;
  }
  .category-link:hover {
    color: var(--accent-gold);
  }

  /* Subcategories Grid */
  .subcategories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .subcategory-card {
    background: var(--bg-card);
    border-radius: 1rem;
    padding: 1.25rem;
    border: 1px solid var(--border);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .subcategory-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.3);
  }
  .subcategory-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .subcategory-title a {
    color: var(--accent-gold);
    text-decoration: none;
  }
  .subcategory-title a:hover {
    text-decoration: underline;
  }
  .subsub-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .subsub-list li a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
    display: inline-block;
  }
  .subsub-list li a:hover {
    color: var(--accent-gold);
    transform: translateX(4px);
  }

  /* Brands Section */
  .brands-section {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .brands-heading {
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--accent-gold);
    margin-bottom: 1.5rem;
  }
  .brands-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .brand-chip {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 2rem;
    padding: 0.5rem 1.2rem;
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.9rem;
    transition: all 0.2s;
  }
  .brand-chip:hover {
    background: var(--accent-gold);
    color: #0f172a;
    border-color: var(--accent-gold);
    transform: translateY(-2px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .categories-page {
      padding: 1rem;
    }
    .page-title {
      font-size: 1.8rem;
    }
    .category-heading {
      font-size: 1.5rem;
    }
    .subcategories-grid {
      grid-template-columns: 1fr;
    }
    .search-form {
      flex-direction: column;
    }
    .search-btn {
      width: 100%;
    }
  }
</style>