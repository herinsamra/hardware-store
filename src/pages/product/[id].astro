---
// src/pages/product/[id].astro
import Layout from '../../components/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getBrandAsset } from '../../lib/brands';
import {
  fetchAllProducts,
  fetchProductByRouteParam,
  getAllProductSlugs,
  getProductUrl,
} from '../../lib/products';

export const prerender = true;

export async function getStaticPaths() {
  const slugs = await getAllProductSlugs();
  return slugs;
}

function cleanName(value: string): string {
  return value.replace(/_/g, ' ');
}

function formatIndianNumber(num: number): string {
  // Convert to absolute value first
  const absNum = Math.abs(num);
  
  // Split the number into integer and decimal parts
  const integerPart = Math.floor(absNum).toString();
  const decimalPart = num % 1 !== 0 ? '.' + Math.round((num % 1) * 100).toString().padStart(2, '0') : '';
  
  // Handle numbers less than 1000
  if (absNum < 1000) {
    return integerPart + decimalPart;
  }
  
  // Extract the last three digits and the rest
  const lastThree = integerPart.slice(-3);
  const rest = integerPart.slice(0, -3);
  
  // Format the rest with commas (every 2 digits after the first comma)
  const restFormatted = rest.replace(/\B(?=(\d{2})+(?!\d))/g, ',');
  
  // Combine everything
  const formattedInteger = rest.length > 0 ? `${restFormatted},${lastThree}` : lastThree;
  
  return formattedInteger + decimalPart;
}

function getFilterUrl(category?: string, subcategory?: string, subsub?: string, brand?: string): string {
  const params = new URLSearchParams();
  if (category) params.set('category', category);
  if (subcategory) params.set('subcategory', subcategory);
  if (subsub) params.set('subsub', subsub);
  if (brand) params.set('brand', brand);
  return `/products?${params.toString()}`;
}

const routeParam = Astro.params.id || '';
const product = await fetchProductByRouteParam(routeParam);

if (!product) {
  return Astro.redirect('/404');
}

const canonicalPath = getProductUrl(product);

if (routeParam !== product.routeParam) {
  return Astro.redirect(canonicalPath, 301);
}

const absoluteCanonicalUrl = Astro.site ? new URL(canonicalPath, Astro.site).toString() : undefined;
const absoluteImageUrl = product.image || undefined;
const brandAsset = getBrandAsset(product.brand);
const productImages = Array.from(new Set(
  (product.images?.length ? product.images : [product.image]).filter(Boolean)
));
const productCategoryTrail = [
  product.category,
  product.subcategory,
  product.subsubcategory,
].filter(Boolean).map(cleanName).join(' > ');
const allProducts = await fetchAllProducts();
const relatedProducts = allProducts
  .filter(relatedProduct => {
    if (relatedProduct.routeParam === product.routeParam || relatedProduct.id === product.id) return false;

    if (product.subsubcategory) {
      return relatedProduct.subsubcategory === product.subsubcategory;
    }

    return relatedProduct.subcategory === product.subcategory;
  })
  .map(relatedProduct => {
    let score = 0;

    if (relatedProduct.brand && relatedProduct.brand === product.brand) score += 2;
    if (relatedProduct.type && relatedProduct.type === product.type) score += 1;

    return { product: relatedProduct, score };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 8)
  .map(item => item.product);

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.meta_description || product.description,
  sku: product.sku || undefined,
  mpn: product.part_no || undefined,
  image: productImages.length ? productImages : (absoluteImageUrl ? [absoluteImageUrl] : undefined),
  category: productCategoryTrail || undefined,
  brand: product.brand ? {
    '@type': 'Brand',
    name: cleanName(product.brand),
  } : undefined,
  url: absoluteCanonicalUrl,
  offers: Number.isFinite(product.price) ? {
    '@type': 'Offer',
    priceCurrency: 'INR',
    price: formatIndianNumber(product.price),
    availability: 'https://schema.org/InStock',
    url: absoluteCanonicalUrl,
  } : undefined,
};
---

<Layout
  title={product.meta_title || `${product.name} | Peniel Hardwares`}
  description={product.meta_description || product.description}
  canonical={canonicalPath}
  image={product.image}
  openGraphType="product"
>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />

  <div class="product-detail-container">
    <div class="product-detail">
      <div class="product-gallery">
        {productImages.length > 0 ? (
          <>
            <div class="product-main-image-shell">
              <img src={productImages[0]} alt={product.name} class="product-detail-image" id="product-main-image" />
            </div>
            {productImages.length > 1 && (
              <div class="product-thumbnail-strip" aria-label="Product images">
                {productImages.map((image, index) => (
                  <button
                    type="button"
                    class:list={['product-thumbnail-button', { active: index === 0 }]}
                    data-product-image={image}
                    aria-label={`Show image ${index + 1}`}
                    aria-pressed={index === 0 ? 'true' : 'false'}
                  >
                    <img src={image} alt={`${product.name} image ${index + 1}`} loading="lazy" />
                  </button>
                ))}
              </div>
            )}
          </>
        ) : (
          <div class="no-image">No image available</div>
        )}
      </div>
      <div class="product-detail-info">
        <h1>{product.name}</h1>
        {product.variant_name && (
          <div class="variant-badge">Variant: {cleanName(product.variant_name)}</div>
        )}
        <div class="product-detail-price">MRP: ₹{formatIndianNumber(product.price)}</div>
        {product.brand && (
          <a href={getFilterUrl(undefined, undefined, undefined, product.brand)} class="product-brand-card" data-astro-prefetch="hover">
            <div class="product-brand-copy">
              <span class="product-brand-label">Brand</span>
              <span class="product-brand-name">{cleanName(product.brand)}</span>
            </div>
            <div class="product-brand-logo-shell">
              {brandAsset ? (
                <img
                  src={brandAsset.url}
                  alt={`${cleanName(product.brand)} logo`}
                  class="product-brand-logo"
                  loading="lazy"
                />
              ) : (
                <span class="product-brand-fallback">{cleanName(product.brand)}</span>
              )}
            </div>
          </a>
        )}
        {product.part_no && <p class="part-no">Part No: {product.part_no}</p>}
        {product.sku && <p class="sku">SKU: {product.sku}</p>}
        <div class="product-detail-description">
          <h3>Description</h3>
          <p>{product.description}</p>
        </div>
        <div class="product-meta">
          <a href={getFilterUrl(product.category)} class="product-meta-tag" data-astro-prefetch="hover">
            {cleanName(product.category)}
          </a>
          {product.subcategory && (
            <a href={getFilterUrl(product.category, product.subcategory)} class="product-meta-tag" data-astro-prefetch="hover">
              {cleanName(product.subcategory)}
            </a>
          )}
          {product.subsubcategory && (
            <a
              href={getFilterUrl(product.category, product.subcategory, product.subsubcategory)}
              class="product-meta-tag"
              data-astro-prefetch="hover"
            >
              {cleanName(product.subsubcategory)}
            </a>
          )}
          {product.subcategory && <span> → {cleanName(product.subcategory)}</span>}
          {product.subsubcategory && <span> → {cleanName(product.subsubcategory)}</span>}
        </div>
        <button class="button add-to-cart">Enquire Now</button>
      </div>
    </div>

    {relatedProducts.length > 0 && (
      <section class="related-products-section" aria-labelledby="related-products-title">
        <div class="related-products-heading">
          <span>Related Products</span>
          <h2 id="related-products-title">You may also love</h2>
        </div>
        <div class="related-products-grid">
          {relatedProducts.map(relatedProduct => (
            <ProductCard product={relatedProduct} />
          ))}
        </div>
      </section>
    )}
  </div>

  <script>
    const productGallery = document.querySelector('.product-gallery');
    const mainImage = document.getElementById('product-main-image');

    if (productGallery instanceof HTMLElement && mainImage instanceof HTMLImageElement) {
      const thumbnailButtons = Array.from(
        productGallery.querySelectorAll('.product-thumbnail-button')
      );

      thumbnailButtons.forEach(button => {
        button.addEventListener('click', () => {
          if (!(button instanceof HTMLButtonElement)) return;

          const nextImage = button.dataset.productImage;
          if (!nextImage) return;

          mainImage.src = nextImage;

          thumbnailButtons.forEach(item => {
            const isActive = item === button;
            item.classList.toggle('active', isActive);
            item.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          });
        });
      });
    }
  </script>
</Layout>

<style is:global>
  .product-detail-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }
  .product-detail {
    display: grid;
    gap: 1.6rem;
    padding: clamp(1.1rem, 2vw, 1.8rem);
    border-radius: 33px;
    background: linear-gradient(145deg, var(--neo-surface-base), var(--neo-surface-low));
    box-shadow:
      inset 14px 14px 28px rgba(7, 10, 17, 0.58),
      inset -14px -14px 28px rgba(103, 124, 161, 0.14),
      20px 20px 40px rgba(0, 0, 0, 0.26);
    border: 1px solid var(--neo-outline);
    position: relative;
    overflow: hidden;
  }
  .product-detail::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.07), transparent 34%),
      radial-gradient(circle at bottom right, rgba(197, 160, 40, 0.12), transparent 26%);
    pointer-events: none;
  }
  @media (min-width: 768px) {
    .product-detail {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: start;
    }
  }
  .product-gallery {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: clamp(0.8rem, 1.6vw, 1.1rem);
    background: linear-gradient(145deg, var(--neo-surface-high), var(--neo-surface-low));
    border-radius: 27px;
    overflow: hidden;
    border: 1px solid var(--neo-outline);
    box-shadow:
      12px 12px 24px rgba(5, 8, 14, 0.4),
      -10px -10px 20px rgba(103, 124, 161, 0.12);
  }
  .product-gallery::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.07), transparent 28%, rgba(10, 15, 24, 0.16));
    pointer-events: none;
  }
  .product-main-image-shell {
    position: relative;
    z-index: 1;
  }
  .product-detail-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    height: auto;
    display: block;
    object-fit: contain;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.02);
  }
  .product-thumbnail-strip {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(74px, 1fr));
    gap: 0.65rem;
  }
  .product-thumbnail-button {
    aspect-ratio: 1 / 1;
    padding: 0.35rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.07);
    background: rgba(255, 255, 255, 0.04);
    box-shadow:
      inset 5px 5px 12px rgba(7, 10, 17, 0.3),
      inset -5px -5px 12px rgba(103, 124, 161, 0.08);
    cursor: pointer;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }
  .product-thumbnail-button:hover,
  .product-thumbnail-button.active {
    transform: translateY(-1px);
    border-color: rgba(197, 160, 40, 0.44);
    box-shadow:
      inset 5px 5px 12px rgba(7, 10, 17, 0.24),
      inset -5px -5px 12px rgba(103, 124, 161, 0.1),
      0 0 0 1px rgba(197, 160, 40, 0.12);
  }
  .product-thumbnail-button img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    border-radius: 12px;
  }
  .no-image {
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.04), rgba(11, 17, 28, 0.2));
    border-radius: 20px;
    color: var(--text-secondary);
  }
  .product-detail-info {
    display: flex;
    flex-direction: column;
    padding: 0.35rem 0.15rem 0.35rem 0.3rem;
  }
  .product-detail-info h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.08;
    margin-bottom: 0.75rem;
    text-wrap: balance;
  }
  .variant-badge {
    width: fit-content;
    background: rgba(197, 160, 40, 0.12);
    color: var(--accent-gold-light);
    display: inline-block;
    padding: 0.45rem 0.95rem;
    border-radius: 999px;
    border: 1px solid rgba(197, 160, 40, 0.18);
    font-size: 0.8rem;
    margin-bottom: 1rem;
  }
  .product-detail-price {
    font-size: clamp(1.9rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--accent-gold);
    margin: 0.2rem 0 1rem;
    text-shadow: 0 0 18px rgba(197, 160, 40, 0.16);
  }
  .product-brand-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 0 1rem;
    padding: 0.95rem 1rem;
    border-radius: 24px;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.05), rgba(10, 16, 27, 0.28));
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow:
      inset 8px 8px 18px rgba(7, 10, 17, 0.26),
      inset -8px -8px 18px rgba(103, 124, 161, 0.07);
    text-decoration: none;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }
  .product-brand-card:hover {
    transform: translateY(-2px);
    border-color: rgba(197, 160, 40, 0.18);
    box-shadow:
      inset 8px 8px 18px rgba(7, 10, 17, 0.24),
      inset -8px -8px 18px rgba(103, 124, 161, 0.09),
      0 12px 28px rgba(0, 0, 0, 0.12);
  }
  .product-brand-copy {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }
  .product-brand-label {
    color: var(--text-secondary);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .product-brand-name {
    color: var(--text-primary);
    font-size: 1rem;
    font-weight: 600;
  }
  .product-brand-logo-shell {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 110px;
    min-height: 72px;
    padding: 0.8rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow:
      8px 8px 18px rgba(7, 10, 17, 0.2),
      -6px -6px 14px rgba(255, 255, 255, 0.08);
  }
  .product-brand-logo {
    max-width: 100%;
    max-height: 42px;
    display: block;
    object-fit: contain;
  }
  .product-brand-fallback {
    color: #1a2334;
    font-size: 0.82rem;
    font-weight: 700;
    text-align: center;
  }
  .part-no, .sku {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 0.45rem;
  }
  .product-detail-description {
    margin: 1.5rem 0 1.2rem;
    padding: 1.15rem 1.2rem;
    border-radius: 24px;
    background: rgba(9, 14, 24, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow:
      inset 8px 8px 18px rgba(7, 10, 17, 0.36),
      inset -8px -8px 18px rgba(103, 124, 161, 0.08);
  }
  .product-detail-description h3 {
    font-size: 1.2rem;
    margin-bottom: 0.65rem;
    color: var(--accent-gold);
  }
  .product-detail-description p {
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .product-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 0 0 1.5rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }
  .product-meta > span {
    display: none;
  }
  .product-meta-tag {
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.04);
    color: var(--text-secondary);
    text-decoration: none;
    box-shadow:
      inset 4px 4px 10px rgba(7, 10, 17, 0.24),
      inset -4px -4px 10px rgba(103, 124, 161, 0.08);
    transition:
      transform 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }
  .product-meta-tag:hover {
    transform: translateY(-1px);
    color: var(--accent-gold-light);
    border-color: rgba(197, 160, 40, 0.18);
    background: rgba(197, 160, 40, 0.08);
  }
  .add-to-cart {
    width: fit-content;
    background: linear-gradient(145deg, #ddb644, #a58115);
    color: #0a0c10;
    border: none;
    padding: 0.85rem 1.6rem;
    border-radius: 999px;
    font-weight: 600;
    cursor: pointer;
    box-shadow:
      10px 10px 22px rgba(7, 10, 17, 0.38),
      -8px -8px 18px rgba(255, 231, 160, 0.14);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      filter 0.2s ease;
  }
  .add-to-cart:hover {
    transform: translateY(-2px);
    filter: brightness(1.05);
    box-shadow:
      14px 14px 26px rgba(7, 10, 17, 0.42),
      -10px -10px 20px rgba(255, 231, 160, 0.18);
  }
  .related-products-section {
    margin-top: 3rem;
  }
  .related-products-heading {
    margin-bottom: 1.4rem;
  }
  .related-products-heading span {
    display: block;
    margin-bottom: 0.35rem;
    color: var(--text-secondary);
    font-size: 0.76rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .related-products-heading h2 {
    color: var(--accent-gold);
    font-size: clamp(1.6rem, 3vw, 2.15rem);
    line-height: 1.15;
  }
  .related-products-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
    align-items: stretch;
  }
  @media (min-width: 768px) {
    .related-products-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  @media (min-width: 1024px) {
    .related-products-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
  @media (max-width: 767px) {
    .product-detail {
      border-radius: 28px;
      box-shadow:
        inset 10px 10px 22px rgba(7, 10, 17, 0.56),
        inset -10px -10px 22px rgba(103, 124, 161, 0.12);
    }

    .product-gallery {
      border-radius: 23px;
    }

    .product-brand-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .product-brand-logo-shell {
      width: 100%;
      min-width: 0;
    }

    .related-products-grid {
      gap: 1rem;
    }
  }
</style>
