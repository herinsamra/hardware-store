---
import Layout from '../components/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { fetchAllProducts } from '../lib/products';

// Define Product type (match what your API returns)
interface Product {
  id: number;
  name: string;
  price: number;
  description?: string;
  category: string;
  subcategory: string;
  subSubcategory?: string;
  sku: string;
  stock: number;
  image: string;
  thumbnail?: string;
}

// Get URL parameters with null checks
const url = new URL(Astro.request.url);
const subcategoryParam = url.searchParams.get('subcategory');
const subSubParam = url.searchParams.get('subsub');
const categoryParam = url.searchParams.get('category');
const brandParam = url.searchParams.get('brand');
const page = parseInt(url.searchParams.get('page') || '1', 10);
const productsPerPage = 12;

// Fetch all products (typed)
const allProducts: Product[] = await fetchAllProducts();

// Filter products
let filteredProducts = allProducts;
if (subSubParam) {
  filteredProducts = allProducts.filter(p => p.subSubcategory === subSubParam);
} else if (subcategoryParam) {
  filteredProducts = allProducts.filter(p => p.subcategory === subcategoryParam);
} else if (categoryParam) {
  filteredProducts = allProducts.filter(p => p.category === categoryParam);
}

// Build page title
let pageTitle = 'All Products';
if (brandParam) {
  pageTitle = `${brandParam} Products`;
} else if (subSubParam) {
  pageTitle = subSubParam;
} else if (subcategoryParam) {
  pageTitle = subcategoryParam;
} else if (categoryParam) {
  pageTitle = `${categoryParam} Products`;
}

// Pagination
const totalProducts = filteredProducts.length;
const totalPages = Math.ceil(totalProducts / productsPerPage);
const startIndex = (page - 1) * productsPerPage;
const paginatedProducts = filteredProducts.slice(startIndex, startIndex + productsPerPage);

// Helper to build pagination URL
function getPageUrl(pageNum: number): string {
  const params = new URLSearchParams(url.searchParams);
  params.set('page', pageNum.toString());
  return `?${params.toString()}`;
}

// Calculate which page numbers to display
let startPage = Math.max(1, page - 2);
let endPage = Math.min(totalPages, page + 2);

if (endPage - startPage < 4) {
  if (startPage === 1) endPage = Math.min(totalPages, startPage + 4);
  if (endPage === totalPages) startPage = Math.max(1, endPage - 4);
}

const pageNumbers: number[] = [];
for (let i = startPage; i <= endPage; i++) {
  pageNumbers.push(i);
}
---

<Layout title={`${pageTitle} | Hardware Store`}>
  <div>
    <div class="mb-6">
      <h1 class="text-2xl sm:text-3xl font-bold text-primary mb-1">
        {pageTitle}
      </h1>
      <p class="text-gray-500">{totalProducts} products found</p>
    </div>
    
    {
      paginatedProducts.length > 0 ? (
        <div class="product-grid">
          {paginatedProducts.map((product: Product) => <ProductCard product={product} />)}
        </div>
      ) : (
        <div class="text-center py-16 bg-white rounded-xl shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
          <p class="text-gray-500 text-lg">No products found in this category.</p>
          <a href="/products" class="inline-block mt-4 text-secondary hover:underline font-medium">
            Browse all products
          </a>
        </div>
      )
    }
    
    {/* Pagination */}
    {totalPages > 1 && (
      <div class="pagination">
        {page > 1 && (
          <a href={getPageUrl(page - 1)} class="flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            Previous
          </a>
        )}
        
        {pageNumbers.map((pageNum) => (
          <a 
            href={getPageUrl(pageNum)}
            class:list={[{ current: pageNum === page }]}
          >
            {pageNum}
          </a>
        ))}
        
        {page < totalPages && (
          <a href={getPageUrl(page + 1)} class="flex items-center gap-1">
            Next
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
          </a>
        )}
      </div>
    )}
  </div>
</Layout>
